FROM wildclawbench-claudecode-ubuntu:v0.2-patched

# PilotDeck needs bun (for run_pilotdeck.mjs) and git (for task warmup/workspace)
COPY bun-bin/bun /usr/local/bin/bun
RUN chmod +x /usr/local/bin/bun && bun --version

RUN apt-get update -qq && apt-get install -y --no-install-recommends git python3.10-venv && \
    rm -rf /var/lib/apt/lists/*

# Create a proper venv at the path sam3 tasks expect (~/miniconda3/envs/eval).
# The base image has a stub dir there; we replace it with a real venv that
# inherits system-site-packages (torch, timm, pillow, etc.) and pins the
# numpy / opencv versions the task warmup requires.
RUN rm -rf /root/miniconda3/envs/eval && \
    python3 -m venv /root/miniconda3/envs/eval --system-site-packages && \
    /root/miniconda3/envs/eval/bin/pip install --no-cache-dir \
      numpy==1.26.4 opencv-python-headless==4.9.0.80

# Install Playwright chromium + system deps for browser-use MCP
RUN npx playwright install --with-deps chromium
